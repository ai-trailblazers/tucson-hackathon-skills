{
  "SessionStart": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "$CLAUDE_PLUGIN_ROOT/scripts/check-registration.sh"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "$CLAUDE_PLUGIN_ROOT/scripts/sniff-bash.sh"
        }
      ]
    },
    {
      "matcher": "Write|Edit",
      "hooks": [
        {
          "type": "command",
          "command": "$CLAUDE_PLUGIN_ROOT/scripts/sniff-write.sh"
        }
      ]
    }
  ]
}
